# ── Proxy Authentication ──────────────────────────────────────────────
# Required for production. Leave empty for local dev only.
ARMOR_API_KEY=your-strong-secret-key-here

# ── LLM Provider Keys (add only the ones you use) ────────────────────
# OpenAI
ARMOR_OPENAI_API_KEY=sk-...

# Anthropic
ARMOR_ANTHROPIC_API_KEY=sk-ant-...

# Azure OpenAI
ARMOR_AZURE_OPENAI_API_KEY=
ARMOR_AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com

# AWS Bedrock — uses boto3 default credential chain if not set
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
ARMOR_AWS_REGION=us-east-1

# Google Gemini
ARMOR_GEMINI_API_KEY=AIza...

# Groq (fastest inference)
ARMOR_GROQ_API_KEY=gsk_...

# Mistral AI
ARMOR_MISTRAL_API_KEY=

# Cohere
ARMOR_COHERE_API_KEY=

# DeepSeek
ARMOR_DEEPSEEK_API_KEY=

# Ollama (local, no key needed)
ARMOR_OLLAMA_BASE_URL=http://localhost:11434

# ── Server ────────────────────────────────────────────────────────────
ARMOR_PORT=8000
ARMOR_WORKERS=1
ARMOR_LOG_LEVEL=INFO

# ── Detection Config ─────────────────────────────────────────────────
ARMOR_INJECTION_ACTION=block        # block | warn | allow
ARMOR_JAILBREAK_ACTION=block
ARMOR_PII_INPUT_ACTION=block
ARMOR_PII_OUTPUT_ACTION=warn
ARMOR_TOXIC_ACTION=block
ARMOR_PII_MASK_OUTPUT=true

# ── Rate Limiting ─────────────────────────────────────────────────────
ARMOR_RATE_LIMIT_ENABLED=true
ARMOR_RATE_LIMIT_REQUESTS=60
ARMOR_REDIS_URL=redis://localhost:6379

# ── Audit Logging ─────────────────────────────────────────────────────
ARMOR_AUDIT_LOG_ENABLED=true
ARMOR_AUDIT_LOG_PATH=/var/log/prompt-armor/audit.jsonl
ARMOR_AUDIT_LOG_HASH_PII=true      # Never stores raw PII

# ── Token Limits ─────────────────────────────────────────────────────
ARMOR_MAX_INPUT_TOKENS=8192
ARMOR_MAX_OUTPUT_TOKENS=4096

# ── Allowlist Bypass Tokens ───────────────────────────────────────────
# Format: TOKEN:MODE,TOKEN:MODE
# Modes: full (skip all), pii (skip PII only), injection (skip injection/jailbreak only)
# Generate: openssl rand -hex 32
# ARMOR_BYPASS_TOKENS=your-strong-token-here:full,another-token:pii

# ── Demo Mode ─────────────────────────────────────────────────────────
# Seed /stats with realistic demo data for README / sales demos
ARMOR_DEMO_MODE=false
